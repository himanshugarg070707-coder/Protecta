<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Turn features ON/OFF based on your preference."
            android:textSize="14sp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchShakeDetection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Enable Shake Detection" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchTapTrigger"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Enable Multi-Tap SOS Trigger" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchVoiceDetection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Enable Voice Panic Detection" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchMotionDetection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Enable Motion Detection" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchAutoSos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Enable Auto SOS on Abnormal Activity" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchMonitoringService"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Enable Background Monitoring Service" />

    </LinearLayout>
</ScrollView>
